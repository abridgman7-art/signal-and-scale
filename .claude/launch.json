{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "python-http-server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "5173"],
      "port": 5173
    },
    {
      "name": "npx-serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "-l", "5174", "."],
      "port": 5174
    },
    {
      "name": "npx-live-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "live-server", "--port=5175", "--no-browser"],
      "port": 5175
    }
  ]
}
